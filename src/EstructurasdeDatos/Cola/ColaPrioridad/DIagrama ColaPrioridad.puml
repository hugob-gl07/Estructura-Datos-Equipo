@startuml
class ColaPrioridadMax <T extends Comparable <T>>{
    + enqueue(dato:T):void
    + dequeue():T
    + peekMax():T
    + isEmpty():boolean
    + size():int
    + clear():void
    + peekMin():T
    + dequeueMin():T
    + toString():String
    + contains(dato:T):T
    + replace(datoviejo:T,datonuevo:T)
}
class ColaPrioridadMin <T extends Comparable <T>>{
    + enqueue(dato:T):void
    + dequeue():T
    + peekMax():T
    + isEmpty():boolean
    + size():int
    + clear():void
    + peekMin():T
    + toString():String
    + contains(dato:T):T
    + replace(datoviejo:T,datonuevo:T)
}

@enduml